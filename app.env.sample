# mssql - app.env.sample
# Copy to app.env and adjust values before starting the stack.

# Timezone
TZ=America/New_York

# Hostname / domain
BASE_HOST_NAME=${HOSTNAME}
BASE_DOMAIN_NAME=example.com

# SQL Server SA (system admin) password — must meet complexity requirements
DB_ADMIN_PASS=changeme_admin_password

# SQL Server product edition: Developer, Express, Standard, Enterprise
MSSQL_PRODUCT_ID=Developer
